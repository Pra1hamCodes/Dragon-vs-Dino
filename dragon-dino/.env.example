# ===========================================
# Dragon-Dino Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# --- Web (prefix VITE_ for client-side access) ---
VITE_API_URL=http://localhost:3001
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_SOCKET_URL=http://localhost:3001

# --- API Server ---
NODE_ENV=development
PORT=3001

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/dragondino

# --- Redis (Upstash) ---
REDIS_URL=redis://localhost:6379

# --- Supabase ---
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# --- JWT (RS256 Asymmetric) ---
# Generate keys: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_ACCESS_SECRET=<64-char-random-string>
JWT_REFRESH_SECRET=<64-char-random-string>
JWT_PRIVATE_KEY=<RS256 private key PEM, replace newlines with \n>
JWT_PUBLIC_KEY=<RS256 public key PEM, replace newlines with \n>

# --- OAuth ---
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GITHUB_CLIENT_ID=xxx
GITHUB_CLIENT_SECRET=xxx

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173,https://dragondino.com

# --- Anti-Cheat ---
MAX_SCORE_RATE=50
GAME_VERSION=1.0.0
